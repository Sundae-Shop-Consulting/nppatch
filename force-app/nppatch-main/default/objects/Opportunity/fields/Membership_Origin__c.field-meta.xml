<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Membership_Origin__c</fullName>
    <description>User-entered picklist for Membership Opportunities. Categorizes how the member was acquired, enabling reporting on new vs. renewed vs. reacquired memberships.</description>
    <externalId>false</externalId>
    <inlineHelpText>Select whether this is a new membership, a renewal of an existing membership, or a reacquired membership from a lapsed member.</inlineHelpText>
    <label>Membership Origin</label>
    <required>false</required>
    <trackFeedHistory>false</trackFeedHistory>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>New</fullName>
                <default>false</default>
                <label>New</label>
            </value>
            <value>
                <fullName>Renewal</fullName>
                <default>false</default>
                <label>Renewal</label>
            </value>
            <value>
                <fullName>Reacquire</fullName>
                <default>false</default>
                <label>Reacquire</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
