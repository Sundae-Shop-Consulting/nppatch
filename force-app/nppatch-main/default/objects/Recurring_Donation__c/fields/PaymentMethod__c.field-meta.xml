<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PaymentMethod__c</fullName>
    <description>Records the payment method for this recurring donation. NPPatch automatically copies this value to the Payment Method field on each installment Payment record when they are created.</description>
    <externalId>false</externalId>
    <inlineHelpText>How donations are collected for this recurring donation (e.g., Credit Card, Check, ACH). Automatically applied to new installment payments.</inlineHelpText>
    <label>Payment Method</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Credit Card</fullName>
                <default>false</default>
                <label>Credit Card</label>
            </value>
            <value>
                <fullName>Check</fullName>
                <default>false</default>
                <label>Check</label>
            </value>
            <value>
                <fullName>ACH</fullName>
                <default>false</default>
                <label>ACH</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
