<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Page_Type__c</fullName>
    <description>Controls which audience-specific Get Started page renders this section. Admin sections appear on the administrator page; End User sections appear on the general user page.</description>
    <externalId>false</externalId>
    <fieldManageability>DeveloperControlled</fieldManageability>
    <inlineHelpText>Whether this section appears on the Admin or End User version of the Get Started page.</inlineHelpText>
    <label>Page Type</label>
    <required>false</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Admin</fullName>
                <default>true</default>
                <label>Admin</label>
            </value>
            <value>
                <fullName>End User</fullName>
                <default>false</default>
                <label>End User</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
