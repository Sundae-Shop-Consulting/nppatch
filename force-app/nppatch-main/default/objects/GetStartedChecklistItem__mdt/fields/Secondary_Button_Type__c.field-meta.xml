<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Secondary_Button_Type__c</fullName>
    <description>Controls the navigation behavior of the secondary button. Disabled renders a non-clickable button; SFDC New Tab opens a Salesforce page; External Page opens a URL in a new browser tab.</description>
    <externalId>false</externalId>
    <fieldManageability>DeveloperControlled</fieldManageability>
    <inlineHelpText>The action the secondary button performs: Disabled (no action), SFDC New Tab (Salesforce page), or External Page (external URL).</inlineHelpText>
    <label>Secondary Button Type</label>
    <required>true</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Disabled</fullName>
                <default>true</default>
                <label>Disabled</label>
            </value>
            <value>
                <fullName>sfdc:new-tab</fullName>
                <default>false</default>
                <label>SFDC New Tab</label>
            </value>
            <value>
                <fullName>link</fullName>
                <default>false</default>
                <label>External Page</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
