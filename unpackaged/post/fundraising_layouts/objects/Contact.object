    <fields>
        <fullName>Formula_HouseholdMailingAddress__c</fullName>
        <description>Formula field. Displays the Household Account&apos;s billing address (or legacy Household&apos;s mailing address). Read-only; update the Account or Address record to change.</description>
        <externalId>false</externalId>
        <formula>IF(Organization_Type__c == &apos;Household Account&apos;,

Account.BillingStreet &amp; BR() &amp;
Account.BillingCity &amp; IF(ISBLANK(Account.BillingCity), &quot;&quot;, &quot;, &quot;) &amp; Account.BillingState &amp; &quot; &quot; &amp; Account.BillingPostalCode
&amp; IF(ISBLANK(Account.BillingCountry), &quot;&quot;, BR()&amp; Account.BillingCountry),

Household__r.Formula_MailingAddress__c)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>The mailing address from this Contact&apos;s Household Account. Read-only.</inlineHelpText>
        <label>Household Mailing Address</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Formula_HouseholdPhone__c</fullName>
        <description>Formula field. Displays the Household Phone from the related Household Account (or legacy Household object). Read-only.</description>
        <externalId>false</externalId>
        <formula>IF(Organization_Type__c == &apos;Household Account&apos;,
Account.HouseholdPhone__c,
Household__r.HouseholdPhone__c)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>The phone number from this Contact&apos;s Household Account. Read-only.</inlineHelpText>
        <label>Household Phone</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
