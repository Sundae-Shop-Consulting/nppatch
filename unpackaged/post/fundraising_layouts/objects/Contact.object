        <fullName>Exclude_from_Household_Formal_Greeting__c</fullName>
        <defaultValue>false</defaultValue>
        <description>When selected, NPPatch excludes this Contact from the Household Formal Greeting (set in NPPatch Settings | People | Households).</description>
        <inlineHelpText>When selected, NPPatch excludes this Contact from the Household Formal Greeting (set in NPPatch Settings | People | Households).</inlineHelpText>
        <label>Exclude from Household Formal Greeting</label>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Exclude_from_Household_Informal_Greeting__c</fullName>
        <defaultValue>false</defaultValue>
        <description>When selected, NPPatch excludes this Contact from the Household Informal Greeting (set in NPPatch Settings | People | Households).</description>
        <inlineHelpText>When selected, NPPatch excludes this Contact from the Household Informal Greeting (set in NPPatch Settings | People | Households).</inlineHelpText>
        <label>Exclude from Household Informal Greeting</label>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Exclude_from_Household_Name__c</fullName>
