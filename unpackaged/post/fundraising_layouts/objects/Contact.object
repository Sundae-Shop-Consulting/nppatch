    <fields>
        <fullName>Preferred_Email__c</fullName>
        <description>Controls which email address is copied to the standard Email field when a Contact is saved. When set, the TDTM trigger framework copies the value from the corresponding custom email field (Personal Email, Work Email, or Alternate Email) to the standard Email field.</description>
        <inlineHelpText>Select which email to use as the primary contact email. The value from the corresponding field (Personal, Work, or Alternate Email) will be copied to the standard Email field on save.</inlineHelpText>
        <label>Preferred Email</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Personal</fullName>
                    <default>true</default>
                    <label>Personal</label>
                </value>
                <value>
                    <fullName>Work</fullName>
                    <default>false</default>
                    <label>Work</label>
                </value>
                <value>
                    <fullName>Alternate</fullName>
                    <default>false</default>
                    <label>Alternate</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
