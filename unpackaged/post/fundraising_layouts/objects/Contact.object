    <fields>
        <fullName>AccountId</fullName>
        <trackFeedHistory>true</trackFeedHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Address_Verification_Status__c</fullName>
        <description>Formula field. Displays the verification status from the Contact&apos;s Current Address record. If verification is needed, navigate to the Address record and select Verify Address.</description>
        <externalId>false</externalId>
        <formula>Current_Address__r.Verification_Status__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>The verification status of this Contact&apos;s current mailing address.</inlineHelpText>
        <label>Address Verification Status</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>AlternateEmail__c</fullName>
        <description>The Contact&apos;s alternate email address. If Preferred Email is set to Alternate, this value is copied to the standard Email field on save.</description>
        <externalId>false</externalId>
        <inlineHelpText>An additional email address for this Contact. If selected as the Preferred Email, this value is used as the standard Email.</inlineHelpText>
        <label>Alternate Email</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>AssistantName</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>AssistantPhone</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>AttendanceRate__c</fullName>
        <formula>IF(NumAbsentServiceDeliveries__c &gt; 0 || NumPresentServiceDeliveries__c &gt; 0 ,
NumPresentServiceDeliveries__c / (NumPresentServiceDeliveries__c + NumAbsentServiceDeliveries__c),
null)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Attendance Rate</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Percent</type>
    </fields>
    <fields>
        <fullName>AttendanceSummary__c</fullName>
        <externalId>false</externalId>
        <formula>IF(NumAbsentServiceDeliveries__c &gt; 0 || NumPresentServiceDeliveries__c &gt; 0,
    TEXT(ROUND(AttendanceRate__c,2)*100) &amp; &quot;% (&quot; &amp; 
    TEXT(NumPresentServiceDeliveries__c) &amp; 
    &quot;/&quot; &amp; 
    TEXT(NumPresentServiceDeliveries__c + NumAbsentServiceDeliveries__c) &amp;
    &quot;)&quot;,
    &quot;&quot;
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Attendance Summary</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>AverageAmount__c</fullName>
        <defaultValue>0</defaultValue>
        <description>Calculated by Customizable Rollups. Do not edit manually. Averages the Amount of all won Opportunities where this Contact has the primary Opportunity Contact Role. Uses the Won Opportunities for Hard Credit filter group.</description>
        <inlineHelpText>The average gift amount across all won Opportunities where this Contact is the primary donor.</inlineHelpText>
        <label>Average Gift</label>
        <precision>16</precision>
        <required>false</required>
        <scale>2</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Best_Gift_Year__c</fullName>
        <description>Calculated by Customizable Rollups. Do not edit manually. The calendar year with the highest total gift amount where this Contact has the primary Opportunity Contact Role. Uses the Won Opportunities for Hard Credit filter group.</description>
        <externalId>false</externalId>
        <inlineHelpText>The calendar year in which this Contact&apos;s total gift amount as primary donor was highest. See also Best Gift Year Total.</inlineHelpText>
        <label>Best Gift Year</label>
        <length>4</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Best_Gift_Year_Total__c</fullName>
        <description>Calculated by Customizable Rollups. Do not edit manually. The sum of Amounts for all won Opportunities in the Best Gift Year where this Contact has the primary Opportunity Contact Role. Uses the Won Opportunities for Hard Credit filter group.</description>
        <inlineHelpText>The total gift amount in this Contact&apos;s Best Gift Year as primary donor.</inlineHelpText>
        <label>Best Gift Year Total</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Birthdate</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>BuyerAttributes</fullName>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Picklist</type>
    </fields>
    <fields>
        <fullName>CleanStatus</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>ConsecutiveAbsences__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>The number of consecutive absences for this Contact, counting back from today. Clears to 0 when most recent Service Delivery was present.</inlineHelpText>
        <label>Consecutive Absences</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>ContactSource</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>Current_Address__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Lookup to the current Address record for this Contact. NPPatch populates the Contact&apos;s Mailing Address field with the street, city, state, and postal code from the current Address record.</description>
        <inlineHelpText>Lookup to the current Address record for this Contact. NPPatch populates the Contact&apos;s Mailing Address field with the street, city, state, and postal code from the current Address record.</inlineHelpText>
        <label>Current Address</label>
        <lookupFilter>
            <active>true</active>
            <filterItems>
                <field>Address__c.Household_Account__c</field>
                <operation>equals</operation>
                <valueField>$Source.AccountId</valueField>
            </filterItems>
            <infoMessage>To see all addresses for the Contact&apos;s household, enter A-* in the search window</infoMessage>
            <isOptional>true</isOptional>
        </lookupFilter>
        <referenceTo>Address__c</referenceTo>
        <relationshipLabel>Contacts (Current Address)</relationshipLabel>
        <relationshipName>Contacts1</relationshipName>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>CustomizableRollups_UseSkewMode__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Forces Customizable Rollups to use Skew Mode for this Contact&apos;s hard credit and soft credit calculations. Enable this for Contacts with an unusually large number of related Opportunities to avoid batch processing limits.</description>
        <inlineHelpText>Check this box to force rollup calculations for this Contact to use Skew Mode, which handles large numbers of related Opportunities.</inlineHelpText>
        <label>Customizable Rollups: Force Skew Mode</label>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Deceased__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Indicates the Contact is deceased. When selected, NPPatch excludes this Contact from Household Naming (unless this Contact is the only one in the Household) and from standard email and phone lists.</description>
        <inlineHelpText>Indicates the Contact is deceased. When selected, NPPatch excludes this Contact from Household Naming (unless this Contact is the only one in the Household) and from standard email and phone lists.</inlineHelpText>
        <label>Deceased</label>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Department</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>Description</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>Do_Not_Contact__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Indicates the Contact does not want your organization to call or email. Use this field to filter out Contacts in email and phone lists. When selected, NPPatch excludes this Contact from Opportunity Acknowledgements.</description>
        <inlineHelpText>Indicates the Contact does not want your organization to call or email. Use this field to filter out Contacts in email and phone lists. When selected, NPPatch excludes this Contact from Opportunity Acknowledgements.</inlineHelpText>
        <label>Do Not Contact</label>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>DoNotCall</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>Email</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
