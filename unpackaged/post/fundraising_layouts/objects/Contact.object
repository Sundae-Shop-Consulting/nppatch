                <value>
                    <fullName>Work</fullName>
                    <default>false</default>
                    <label>Work</label>
                </value>
                <value>
                    <fullName>Mobile</fullName>
                    <default>false</default>
                    <label>Mobile</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
