    </searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
    <fields>
        <fullName>Active__c</fullName>
        <defaultValue>true</defaultValue>
        <description>Controls whether this GAU appears in Allocation lookup filters. Defaults to true. Unchecking prevents new Allocations from referencing this GAU but does not affect existing Allocations.</description>
        <inlineHelpText>Whether this fund is available for new allocations. Uncheck to retire a fund without deleting it or its history.</inlineHelpText>
        <label>Active</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Average_Allocation__c</fullName>
        <defaultValue>0</defaultValue>
        <description>Calculated by Customizable Rollups. Do not edit manually.</description>
        <inlineHelpText>The average dollar amount across all Allocations from Closed/Won Opportunities to this fund.</inlineHelpText>
        <label>Average Allocation</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <description>Free-text field for notes about this GAU. Not used by automation.</description>
        <inlineHelpText>Details about this fund&apos;s purpose, restrictions, or guidelines for use.</inlineHelpText>
        <label>Description</label>
        <length>32768</length>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>First_Allocation_Date__c</fullName>
        <description>Calculated by Customizable Rollups. Do not edit manually.</description>
        <inlineHelpText>The earliest Opportunity Close Date among all Allocations to this fund.</inlineHelpText>
        <label>First Allocation Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Largest_Allocation__c</fullName>
        <defaultValue>0</defaultValue>
        <description>Calculated by Customizable Rollups. Do not edit manually.</description>
        <inlineHelpText>The largest single Allocation amount from a Closed/Won Opportunity to this fund.</inlineHelpText>
        <label>Largest Allocation</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Last_Allocation_Date__c</fullName>
        <description>Calculated by Customizable Rollups. Do not edit manually.</description>
        <inlineHelpText>The most recent Opportunity Close Date among all Allocations to this fund.</inlineHelpText>
        <label>Last Allocation Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Number_of_Allocations_Last_N_Days__c</fullName>
        <defaultValue>0</defaultValue>
        <description>Calculated by Customizable Rollups. Do not edit manually. The N-day window is configured in NPPatch Settings under Donations &gt; GAU Allocations.</description>
        <externalId>false</externalId>
        <inlineHelpText>The count of Allocations from Closed/Won Opportunities in the last N days. The value of N is configured in NPPatch Settings.</inlineHelpText>
        <label>Number of Allocations Last N Days</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
