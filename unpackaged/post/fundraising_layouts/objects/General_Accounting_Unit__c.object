        <description>Calculated by Customizable Rollups. Do not edit manually.</description>
        <externalId>false</externalId>
        <inlineHelpText>The count of Allocations from Closed/Won Opportunities with a Close Date in the previous calendar year.</inlineHelpText>
        <label>Number of Allocations Last Year</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
