    <compactLayouts>
        <fullName>NPPatch_Relationship_Compact_Layout</fullName>
        <fields>Name</fields>
        <fields>Contact__c</fields>
        <fields>RelatedContact__c</fields>
        <label>NPPatch Relationship Compact Layout</label>
    </compactLayouts>
    <fields>
        <fullName>Contact__c</fullName>
        <description>Master-detail lookup to the primary Contact in this Relationship. Set when the record is created; the reciprocal Relationship record references this Contact via RelatedContact__c.</description>
        <inlineHelpText>The Contact whose relationship to the Related Contact is being described. For example, if the Type is &quot;Father,&quot; then the Related Contact is this Contact&apos;s father.</inlineHelpText>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Relationships</relationshipLabel>
        <relationshipName>Relationships</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <description>Free-text field for notes about this Relationship. Not used by automation.</description>
        <inlineHelpText>Optional notes or context about this Relationship, such as how the two Contacts met or the nature of their connection.</inlineHelpText>
        <label>Description</label>
        <length>32000</length>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>6</visibleLines>
    </fields>
    <fields>
        <fullName>ReciprocalRelationship__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Populated automatically by NPPatch when a Relationship is created. Links to the mirror Relationship record with the reciprocal Type. Do not edit manually.</description>
        <inlineHelpText>The other side of this Relationship. For example, if this record says Contact A is Contact B&apos;s father, the reciprocal record says Contact B is Contact A&apos;s child.</inlineHelpText>
        <label>Reciprocal Relationship</label>
        <referenceTo>Relationship__c</referenceTo>
        <relationshipLabel>Relationships</relationshipLabel>
        <relationshipName>Relationships</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Related_Opportunity_Contact_Role__c</fullName>
        <description>NPPatch automation reads this value when an Opportunity is created for the primary Contact and creates an Opportunity Contact Role on the Related Contact with the selected role.</description>
        <inlineHelpText>The Opportunity Contact Role automatically assigned to the Related Contact when a donation is made by this Contact. For example, select Soft Credit to give the Related Contact soft credit for those donations.</inlineHelpText>
        <label>Related Opportunity Contact Role</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Soft Credit</fullName>
                    <default>false</default>
                    <label>Soft Credit</label>
                </value>
                <value>
                    <fullName>Solicitor</fullName>
                    <default>false</default>
                    <label>Solicitor</label>
                </value>
                <value>
                    <fullName>Tribute</fullName>
                    <default>false</default>
                    <label>Tribute</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>RelatedContact__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Lookup to the second Contact in this Relationship. Set when the Relationship is created. The reciprocal Relationship record references this Contact as its primary Contact.</description>
        <inlineHelpText>The other person in this Relationship. The Type field describes how this person is related to the Contact.</inlineHelpText>
        <label>Related Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Hidden Relationships List</relationshipLabel>
        <relationshipName>Relationships1</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Relationship_Explanation__c</fullName>
        <description>Formula field that concatenates the Related Contact name, a connector label, the Contact name, and the Type into a human-readable sentence. Recalculated automatically.</description>
        <externalId>false</externalId>
        <formula>TEXT(RelatedContact__r.Salutation) + &quot; &quot; + RelatedContact__r.FirstName + &quot; &quot; + RelatedContact__r.LastName
+ &quot;  &quot;  +  $Label.Relationship_Explanation_Connector + &quot; &quot; +
TEXT(Contact__r.Salutation) + &quot; &quot; + Contact__r.FirstName + &quot; &quot; + Contact__r.LastName + &quot;&apos;s &quot; + TEXT(Type__c)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>A read-only sentence describing the relationship, e.g. &quot;Jane Smith is John Smith&apos;s Spouse.&quot;</inlineHelpText>
        <label>Relationship Explanation</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Status__c</fullName>
        <description>Picklist indicating whether this Relationship is active. Defaults to Current. Changes are mirrored to the reciprocal Relationship record.</description>
        <inlineHelpText>Whether this Relationship is currently active (Current) or no longer active (Former).</inlineHelpText>
        <label>Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Current</fullName>
                    <default>true</default>
                    <label>Current</label>
                </value>
                <value>
                    <fullName>Former</fullName>
                    <default>false</default>
                    <label>Former</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>SYSTEM_SystemCreated__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Set to true by NPPatch automation when this record is the auto-created reciprocal of a user-created Relationship. Used internally to prevent infinite reciprocal creation loops. Do not edit manually.</description>
        <inlineHelpText>Indicates this Relationship was automatically created as the reciprocal side of another Relationship rather than entered by a user.</inlineHelpText>
        <label>_SYSTEM: SystemCreated</label>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Type__c</fullName>
        <description>Drives the reciprocal Type on the mirror Relationship record via Relationship Lookup mappings in NPPatch Settings. For example, setting Father here creates a Child reciprocal.</description>
        <inlineHelpText>How the Related Contact is related to the Contact, e.g. Father, Spouse, Friend. The reciprocal Relationship will automatically get the opposite type.</inlineHelpText>
        <label>Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Friend</fullName>
                    <default>false</default>
                    <label>Friend</label>
                </value>
                <value>
                    <fullName>Family</fullName>
                    <default>false</default>
                    <label>Family</label>
                </value>
                <value>
                    <fullName>Coworker</fullName>
                    <default>false</default>
                    <label>Coworker</label>
                </value>
                <value>
                    <fullName>Father</fullName>
                    <default>false</default>
                    <label>Father</label>
                </value>
                <value>
                    <fullName>Mother</fullName>
                    <default>false</default>
                    <label>Mother</label>
                </value>
                <value>
                    <fullName>Parent</fullName>
                    <default>false</default>
                    <label>Parent</label>
                </value>
                <value>
                    <fullName>Son</fullName>
                    <default>false</default>
                    <label>Son</label>
                </value>
                <value>
                    <fullName>Daughter</fullName>
                    <default>false</default>
                    <label>Daughter</label>
                </value>
                <value>
                    <fullName>Child</fullName>
                    <default>false</default>
                    <label>Child</label>
                </value>
                <value>
                    <fullName>Aunt</fullName>
                    <default>false</default>
                    <label>Aunt</label>
                </value>
                <value>
                    <fullName>Uncle</fullName>
                    <default>false</default>
                    <label>Uncle</label>
                </value>
                <value>
                    <fullName>Husband</fullName>
                    <default>false</default>
                    <label>Husband</label>
                </value>
                <value>
                    <fullName>Wife</fullName>
                    <default>false</default>
                    <label>Wife</label>
                </value>
                <value>
                    <fullName>Partner</fullName>
                    <default>false</default>
                    <label>Partner</label>
                </value>
                <value>
                    <fullName>Cousin</fullName>
                    <default>false</default>
                    <label>Cousin</label>
                </value>
                <value>
                    <fullName>Grandmother</fullName>
                    <default>false</default>
                    <label>Grandmother</label>
                </value>
                <value>
                    <fullName>Grandfather</fullName>
                    <default>false</default>
                    <label>Grandfather</label>
                </value>
                <value>
                    <fullName>Grandparent</fullName>
                    <default>false</default>
                    <label>Grandparent</label>
                </value>
                <value>
                    <fullName>Grandson</fullName>
                    <default>false</default>
                    <label>Grandson</label>
                </value>
                <value>
                    <fullName>Granddaughter</fullName>
                    <default>false</default>
                    <label>Granddaughter</label>
                </value>
                <value>
                    <fullName>Grandchild</fullName>
                    <default>false</default>
                    <label>Grandchild</label>
                </value>
                <value>
                    <fullName>Employer</fullName>
                    <default>false</default>
                    <label>Employer</label>
                </value>
                <value>
                    <fullName>Employee</fullName>
                    <default>false</default>
                    <label>Employee</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Contact__c</columns>
        <columns>RelatedContact__c</columns>
        <columns>Type__c</columns>
        <columns>Status__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <validationRules>
        <fullName>Related_Contact_Do_Not_Change</fullName>
        <active>true</active>
        <description>Do not allow user to change Related Contact value as it damages the paired relationship data</description>
        <errorConditionFormula>and(not( ISNEW()), ISCHANGED( RelatedContact__c ))</errorConditionFormula>
        <errorDisplayField>RelatedContact__c</errorDisplayField>
        <errorMessage>Rather than change the contacts in an existing relationship, delete this relationship and create a new on between the new contacts</errorMessage>
    </validationRules>
</CustomObject>
