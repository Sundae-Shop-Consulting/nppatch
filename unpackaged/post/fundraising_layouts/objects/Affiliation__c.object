    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>true</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>ControlledByParent</externalSharingModel>
    <label>Affiliation</label>
    <nameField>
        <displayFormat>AF-{000000}</displayFormat>
        <label>Affiliation Name</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Affiliations</pluralLabel>
    <searchLayouts>
        <lookupDialogsAdditionalFields>Contact__c</lookupDialogsAdditionalFields>
        <lookupDialogsAdditionalFields>Organization__c</lookupDialogsAdditionalFields>
        <lookupDialogsAdditionalFields>Role__c</lookupDialogsAdditionalFields>
        <lookupPhoneDialogsAdditionalFields>Contact__c</lookupPhoneDialogsAdditionalFields>
        <lookupPhoneDialogsAdditionalFields>Organization__c</lookupPhoneDialogsAdditionalFields>
        <lookupPhoneDialogsAdditionalFields>Role__c</lookupPhoneDialogsAdditionalFields>
        <searchFilterFields>Contact__c</searchFilterFields>
        <searchFilterFields>Organization__c</searchFilterFields>
        <searchFilterFields>Role__c</searchFilterFields>
        <searchFilterFields>Status__c</searchFilterFields>
        <searchResultsAdditionalFields>Contact__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Organization__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Role__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Status__c</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ControlledByParent</sharingModel>
    <visibility>Public</visibility>
    <compactLayouts>
        <fullName>NPPatch_Affiliation_Compact_Layout</fullName>
        <fields>Name</fields>
        <fields>Organization__c</fields>
        <fields>Contact__c</fields>
        <label>NPPatch Affiliation Compact Layout</label>
    </compactLayouts>
    <fields>
        <fullName>Contact__c</fullName>
        <description>Master-detail lookup to the Contact in this Affiliation. Set automatically when the Affiliation record is created.</description>
        <inlineHelpText>The person affiliated with this Organization.</inlineHelpText>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Organization Affiliations</relationshipLabel>
        <relationshipName>Affiliations</relationshipName>
        <relationshipOrder>1</relationshipOrder>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <description>Free-text field for notes about this Affiliation. Not used by automation.</description>
        <inlineHelpText>Additional details about this Contact&apos;s relationship with the Organization, such as department or job title context.</inlineHelpText>
        <label>Description</label>
        <length>32000</length>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>6</visibleLines>
    </fields>
    <fields>
        <fullName>EndDate__c</fullName>
        <description>User-entered date. Not populated automatically. Typically updated when Status changes to Former.</description>
        <inlineHelpText>The date the Contact&apos;s affiliation with this Organization ended.</inlineHelpText>
        <label>End Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Organization__c</fullName>
        <description>Master-detail lookup to the Organization Account. When Primary is checked, this value syncs to Contact.Primary_Affiliation__c.</description>
        <inlineHelpText>The Organization Account this Contact is affiliated with.</inlineHelpText>
        <label>Organization</label>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Affiliated Contacts</relationshipLabel>
        <relationshipName>Affiliations</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Primary__c</fullName>
        <defaultValue>false</defaultValue>
        <description>When checked, automation copies the Organization to Contact.Primary_Affiliation__c. Only one Affiliation per Contact should be marked Primary.</description>
        <inlineHelpText>Marks this as the Contact&apos;s primary organizational affiliation. The Organization will be stored on the Contact record.</inlineHelpText>
        <label>Primary</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Related_Opportunity_Contact_Role__c</fullName>
        <description>NPPatch automation reads this value when an Opportunity is created for the affiliated Organization and creates an Opportunity Contact Role on the affiliated Contact with the selected role.</description>
        <inlineHelpText>The Opportunity Contact Role automatically assigned to this Contact when a donation is made to the affiliated Organization. For example, select Soft Credit to give this Contact soft credit for those donations.</inlineHelpText>
        <label>Related Opportunity Contact Role</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Soft Credit</fullName>
                    <default>false</default>
                    <label>Soft Credit</label>
                </value>
                <value>
                    <fullName>Solicitor</fullName>
                    <default>false</default>
                    <label>Solicitor</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Role__c</fullName>
        <description>Free-text field describing the Contact&apos;s role at the Organization. Not used by automation; for informational purposes only.</description>
        <externalId>false</externalId>
        <inlineHelpText>The Contact&apos;s role at this Organization, such as Employee, Board Member, or Volunteer.</inlineHelpText>
        <label>Role</label>
        <length>255</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>StartDate__c</fullName>
        <description>User-entered date. Not populated automatically. Typically set when the Affiliation is first created.</description>
        <inlineHelpText>The date the Contact&apos;s affiliation with this Organization began.</inlineHelpText>
        <label>Start Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Status__c</fullName>
        <description>Picklist indicating whether this Affiliation is active. Defaults to Current. Not changed automatically by NPPatch.</description>
        <inlineHelpText>Whether this affiliation is currently active (Current) or no longer active (Former).</inlineHelpText>
        <label>Status</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Current</fullName>
                    <default>true</default>
                    <label>Current</label>
                </value>
                <value>
                    <fullName>Former</fullName>
                    <default>false</default>
                    <label>Former</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Contact__c</columns>
        <columns>Organization__c</columns>
        <columns>Role__c</columns>
        <columns>Status__c</columns>
        <columns>Primary__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
</CustomObject>
