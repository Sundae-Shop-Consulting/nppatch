    <fields>
        <fullName>Recurring_Donation__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Lookup to Recurring Donation. Populated automatically when NPPatch creates installment Opportunities from a Recurring Donation schedule.</description>
        <inlineHelpText>The Recurring Donation that generated this Opportunity. This field is typically set automatically.</inlineHelpText>
        <label>Recurring Donation</label>
        <referenceTo>Recurring_Donation__c</referenceTo>
        <relationshipLabel>Opportunities</relationshipLabel>
        <relationshipName>Donations</relationshipName>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Recurring_Donation_Installment_Name__c</fullName>
        <description>Formula field. Generates a display label for this installment, showing the installment number in parentheses for open-ended Recurring Donations or as &quot;X of Y&quot; for fixed-length schedules. Used in Opportunity naming conventions.</description>
        <externalId>false</externalId>
        <formula>IF(
ISBLANK(Recurring_Donation__c),
&apos;&apos;,
  IF(
    OR(ISPICKVAL(Recurring_Donation__r.Open_Ended_Status__c, &apos;Open&apos;),ISPICKVAL(Recurring_Donation__r.Open_Ended_Status__c, &apos;Closed&apos;),ISBLANK(Recurring_Donation__r.Installments__c)),
    &apos;(&apos;&amp;TEXT(Recurring_Donation_Installment_Number__c)&amp;&apos;)&apos;,
    &apos;(&apos;&amp;TEXT(Recurring_Donation_Installment_Number__c)&amp;&apos; &apos;&amp;$Label.oppInstallmentsOf&amp;&apos; &apos;&amp;TEXT(Recurring_Donation__r.Installments__c)&amp;&apos;)&apos;
  )
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>The installment label for this Recurring Donation Opportunity, such as &quot;(3)&quot; for open-ended or &quot;(3 of 12)&quot; for fixed-length schedules.</inlineHelpText>
        <label>Recurring Donation Installment Name</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Recurring_Donation_Installment_Number__c</fullName>
        <description>System-populated number field. Set automatically when NPPatch creates installment Opportunities, indicating this Opportunity&apos;s position in the Recurring Donation schedule.</description>
        <externalId>false</externalId>
        <inlineHelpText>Which installment this Opportunity represents in the Recurring Donation schedule (e.g., 1, 2, 3).</inlineHelpText>
        <label>Recurring Donation Installment Number</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
