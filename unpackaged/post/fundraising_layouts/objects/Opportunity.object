    <fields>
        <fullName>AccountId</fullName>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Acknowledgment_Date__c</fullName>
        <description>User-entered date field used in thank-you letter and acknowledgment tracking workflows.</description>
        <inlineHelpText>The date you sent an acknowledgment or thank-you letter for this Donation.</inlineHelpText>
        <label>Acknowledgment Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Acknowledgment_Status__c</fullName>
        <description>User-entered picklist for tracking the acknowledgment lifecycle. Used by reports and filters to identify Donations needing thank-you letters.</description>
        <inlineHelpText>Select the current acknowledgment status for this Donation, such as whether a thank-you letter still needs to be sent.</inlineHelpText>
        <label>Acknowledgment Status</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>To Be Acknowledged</fullName>
                    <default>false</default>
                    <label>To Be Acknowledged</label>
                </value>
                <value>
                    <fullName>Acknowledged</fullName>
                    <default>false</default>
                    <label>Acknowledged</label>
                </value>
                <value>
                    <fullName>Do Not Acknowledge</fullName>
                    <default>false</default>
                    <label>Do Not Acknowledge</label>
                </value>
                <value>
                    <fullName>Email Acknowledgment Now</fullName>
                    <default>false</default>
                    <label>Email Acknowledgment Now</label>
                </value>
                <value>
                    <fullName>Email Acknowledgment Not Sent</fullName>
                    <default>false</default>
                    <label>Email Acknowledgment Not Sent</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Amount</fullName>
        <trackFeedHistory>true</trackFeedHistory>
        <trackTrending>false</trackTrending>
    </fields>
    <fields>
        <fullName>Amount_Outstanding__c</fullName>
        <description>Formula field. Calculates Amount minus Payment Amount Received and Payment Writeoff Amount. Used to track unpaid balances across Opportunities.</description>
        <formula>Amount - NULLVALUE(Payments_Made__c, 0) - NULLVALUE(Amount_Written_Off__c, 0)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>The remaining balance still owed on this Donation after subtracting payments received and amounts written off.</inlineHelpText>
        <label>Remaining Balance</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Amount_Written_Off__c</fullName>
        <description>Rollup summary field. Sums the Payment Amount from related Payment records where Written Off is true.</description>
        <inlineHelpText>The total value of Payments marked as written off or noncollectable for this Donation.</inlineHelpText>
        <label>Payment Writeoff Amount</label>
        <summarizedField>OppPayment__c.Payment_Amount__c</summarizedField>
        <summaryFilterItems>
            <field>OppPayment__c.Written_Off__c</field>
            <operation>equals</operation>
            <value>True</value>
        </summaryFilterItems>
        <summaryForeignKey>OppPayment__c.Opportunity__c</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>Ask_Date__c</fullName>
        <description>User-entered date for tracking the solicitation timeline. Records when the ask was made, independent of the Close Date when the gift was received.</description>
        <inlineHelpText>Enter the date the donor was solicited for this Donation. This may differ from the Close Date when the gift was received.</inlineHelpText>
        <label>Ask Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Batch_Number__c</fullName>
        <description>System field. Automatically populated with a batch identifier when Opportunities are created through batch data entry, based on Batch Number Settings in NPPatch Settings.</description>
        <externalId>false</externalId>
        <inlineHelpText>The batch identifier assigned when this Opportunity was created through batch data entry. This value is set automatically.</inlineHelpText>
        <label>Batch Number</label>
        <length>30</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>CampaignId</fullName>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Closed_Lost_Reason__c</fullName>
        <description>Free-text field for recording why a solicitation was unsuccessful. Useful for analyzing trends in lost Opportunities.</description>
        <inlineHelpText>Enter the reason this Donation was not completed, to help your team learn from unsuccessful asks.</inlineHelpText>
        <label>Closed Lost Reason</label>
        <length>32768</length>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>CloseDate</fullName>
        <trackFeedHistory>true</trackFeedHistory>
        <trackTrending>false</trackTrending>
    </fields>
    <fields>
        <fullName>CombinedRollupFieldset__c</fullName>
        <description>Formula field. System-only. Concatenates CloseDate, Amount, Member Level, Membership Origin, and Id into a single text value used internally by rollup calculations to identify the most recent Opportunity. Do not add to page layouts.</description>
        <externalId>false</externalId>
        <formula>TEXT(CloseDate) + &apos;;|;&apos;+ TEXT(Amount) + &apos;;|;&apos;+ TEXT(Member_Level__c) + &apos;;|;&apos;+ TEXT(Membership_Origin__c) + &apos;;|;&apos; +  Id</formula>
        <inlineHelpText>System field used internally by NPPatch rollup calculations. Not intended for display on page layouts.</inlineHelpText>
        <label>Combined Rollup Fieldset</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact_Id_for_Role__c</fullName>
        <description>System field. Temporarily stores a Contact Id during Opportunity Contact Role creation automation. Populated and cleared by triggers; not intended for manual entry or page layouts.</description>
        <externalId>false</externalId>
        <inlineHelpText>System-managed field used internally by NPPatch. Do not edit manually.</inlineHelpText>
        <label>Contact Id for Role</label>
        <length>255</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>ContractId</fullName>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Description</fullName>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
    </fields>
    <fields>
        <fullName>DisableContactRoleAutomation__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Automation toggle. When checked, suppresses automatic Opportunity Contact Role creation and updates by NPPatch triggers on this Opportunity. Use with caution as it may cause incomplete or duplicate Contact Role data.</description>
        <inlineHelpText>Check this box to prevent NPPatch from automatically creating or updating Contact Roles on this Opportunity. Use only when you need to manage Contact Roles manually.</inlineHelpText>
        <label>Disable Contact Role Automation</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Do_Not_Automatically_Create_Payment__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Automation toggle. When checked, suppresses automatic Payment record creation by NPPatch triggers on this Opportunity. Only applies when Automatic Payment Creation is enabled in NPPatch Settings.</description>
        <inlineHelpText>Check this box to prevent NPPatch from automatically creating a Payment record when this Opportunity is saved. Use when you plan to create Payments manually.</inlineHelpText>
        <label>Do Not Automatically Create Payment</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>ExpectedRevenue</fullName>
        <trackTrending>false</trackTrending>
    </fields>
    <fields>
        <fullName>Fair_Market_Value__c</fullName>
        <description>User-entered currency field for In-Kind Donations. Records the assessed fair market value of donated goods or services, which may differ from the Opportunity Amount.</description>
        <inlineHelpText>Enter the estimated fair market value of the donated goods or services.</inlineHelpText>
        <label>Fair Market Value</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Gift_Strategy__c</fullName>
        <description>User-entered restricted picklist for categorizing the fundraising approach. Enables reporting on acquisition vs. retention strategies.</description>
        <inlineHelpText>Select the fundraising strategy for this Donation, such as New Donor, Renewal, or Upgrade.</inlineHelpText>
        <label>Gift Strategy</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>New Donor</fullName>
                    <default>false</default>
                    <label>New Donor</label>
                </value>
                <value>
                    <fullName>Renewal</fullName>
                    <default>false</default>
                    <label>Renewal</label>
                </value>
                <value>
                    <fullName>Upgrade</fullName>
                    <default>false</default>
                    <label>Upgrade</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Grant_Contract_Date__c</fullName>
        <description>User-entered date for Grant Opportunities. Records the inception date from the grant contract or award letter.</description>
        <inlineHelpText>Enter the date of the grant contract or award letter from the grantmaking organization.</inlineHelpText>
        <label>Grant Contract Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Grant_Contract_Number__c</fullName>
        <description>User-entered text field for Grant Opportunities. Stores the contract or reference number assigned by the grantmaking organization.</description>
        <externalId>false</externalId>
        <inlineHelpText>Enter the unique contract or reference number assigned by the grantmaker, if applicable.</inlineHelpText>
        <label>Grant Contract Number</label>
        <length>255</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Grant_Period_End_Date__c</fullName>
        <description>User-entered date for Grant Opportunities. Defines the end of the grant period for tracking spending and reporting deadlines.</description>
        <inlineHelpText>Enter the date when the grant funding period ends.</inlineHelpText>
        <label>Grant Period End Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Grant_Period_Start_Date__c</fullName>
        <description>User-entered date for Grant Opportunities. Defines the start of the grant period for tracking spending and reporting timelines.</description>
        <inlineHelpText>Enter the date when the grant funding period begins.</inlineHelpText>
        <label>Grant Period Start Date</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Grant_Program_Area_s__c</fullName>
        <description>Free-text field for Grant Opportunities. Records which programs or funding areas the grant is designated for, enabling reporting by program.</description>
        <inlineHelpText>Enter the programs or funding areas this Grant or Donation is designated for.</inlineHelpText>
        <label>Program Areas</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>Grant_Requirements_Website__c</fullName>
        <description>URL field for Grant Opportunities. Stores a link to the grantmaker&apos;s requirements page for quick reference during application and reporting.</description>
        <inlineHelpText>Enter the URL for the grantmaker&apos;s requirements or application guidelines page.</inlineHelpText>
        <label>Grant Requirements Website</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>Honoree_Contact__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Lookup to Contact. Links a tribute gift to an existing Contact record for the honoree. If populated, NPPatch auto-fills the Honoree Name field.</description>
        <inlineHelpText>Select the Contact record for the person being honored or memorialized by this Donation.</inlineHelpText>
        <label>Honoree Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Opportunities (Honoree Contact)</relationshipLabel>
        <relationshipName>Honoree_Opportunities</relationshipName>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Honoree_Information__c</fullName>
        <description>Free-text field for storing contact details about the tribute honoree that the donor provided. Not linked to a Contact record.</description>
        <inlineHelpText>Enter any contact information the donor provided for the honoree, such as email, address, or phone number.</inlineHelpText>
        <label>Honoree Information</label>
        <length>32768</length>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>10</visibleLines>
    </fields>
    <fields>
        <fullName>Honoree_Name__c</fullName>
        <description>Text field for the honoree&apos;s name. Auto-populated from the Honoree Contact lookup if left blank; can also be entered manually when no Contact record exists.</description>
        <externalId>false</externalId>
        <inlineHelpText>The name of the person being honored or memorialized. If you select a Honoree Contact, this field is filled in automatically.</inlineHelpText>
        <label>Honoree Name</label>
        <length>255</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>In_Kind_Description__c</fullName>
        <description>Rich text field for In-Kind Donations. Supports formatted text and images for documenting donated goods or services.</description>
        <inlineHelpText>Describe the donated goods or services in detail. This field supports rich text formatting and images.</inlineHelpText>
        <label>In-Kind Description</label>
        <length>32768</length>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Html</type>
        <visibleLines>10</visibleLines>
    </fields>
    <fields>
        <fullName>In_Kind_Donor_Declared_Value__c</fullName>
        <defaultValue>false</defaultValue>
        <description>User-entered checkbox for In-Kind Donations. Tracks whether the Fair Market Value was declared by the donor versus assessed independently. Important for tax receipt and audit purposes.</description>
        <inlineHelpText>Check this box if the donor provided the Fair Market Value amount, rather than your organization determining it independently.</inlineHelpText>
        <label>In-Kind Donor Declared Value</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>In_Kind_Type__c</fullName>
        <description>User-entered picklist for In-Kind Donations. Categorizes the donation as Goods or Services for reporting and tax receipt purposes.</description>
        <inlineHelpText>Select whether this In-Kind Donation is a gift of goods or a donation of services.</inlineHelpText>
        <label>In-Kind Type</label>
