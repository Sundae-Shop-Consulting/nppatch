        <summaryFilterItems>
            <field>Grant_Deadline__c.Grant_Deliverable_Close_Date__c</field>
            <operation>equals</operation>
            <value></value>
        </summaryFilterItems>
        <summaryForeignKey>Grant_Deadline__c.Opportunity__c</summaryForeignKey>
